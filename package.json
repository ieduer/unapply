{
  "name": "unapply",
  "private": true,
  "version": "1.0.0",
  "description": "你一定不考哪所大學 — 用減法從教育部 2025 普通高校名單中劃掉不能忍的那批",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "data:schools": "node scripts/build_official_schools.mjs",
    "data:github-profiles": "node scripts/extract_github_school_profiles.mjs",
    "data:laosheng-profiles": "node scripts/extract_laosheng_school_profiles.mjs",
    "data:campus-extract": "node scripts/extract_campus_locations.mjs",
    "data:research": "node scripts/build_research_data.mjs && node scripts/build_campus_research.mjs && tsx scripts/export_runtime_payloads.ts",
    "data:runtime": "tsx scripts/export_runtime_payloads.ts",
    "audit:questions": "node scripts/audit_question_rules.mjs",
    "audit:data": "tsx scripts/audit_data_coverage.mjs",
    "build": "npm run data:runtime && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pages:deploy": "npm run build && npx wrangler pages deploy dist --project-name unapply --branch master --commit-dirty=true"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@e965/xlsx": "^0.20.3",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wrangler": "^4.80.0"
  }
}
